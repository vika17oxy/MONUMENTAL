<?xml version="1.0"?>
<!-- Cement nozzle tool with one revolute for application angle. -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="tool_cement" params="prefix parent">

    <joint name="${prefix}cement_base_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${prefix}cement_base"/>
      <origin xyz="0 0 0.04"/>
    </joint>
    <link name="${prefix}cement_base">
      <visual><geometry><cylinder radius="0.04" length="0.08"/></geometry><origin xyz="0 0 0.04"/><material name="tool_red"><color rgba="0.7 0.1 0.1 1"/></material></visual>
      <collision><geometry><cylinder radius="0.04" length="0.08"/></geometry><origin xyz="0 0 0.04"/></collision>
      <inertial><mass value="0.6"/><inertia ixx="0.0005" iyy="0.0005" izz="0.0005" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>

    <joint name="${prefix}cement_angle" type="revolute">
      <parent link="${prefix}cement_base"/>
      <child link="${prefix}nozzle"/>
      <origin xyz="0 0 0.08"/>
      <axis xyz="0 1 0"/>
      <limit lower="-1.57" upper="1.57" effort="5" velocity="1.0"/>
    </joint>
    <!-- LONG thin nozzle: the tip (tcp) sits 0.33 m below the angle joint (0.45 m
         below the wrist). VIKA-5 then holds its WRIST at the comfortably-reachable
         height while the long nozzle reaches all the way DOWN to the brick top — so
         the tip applies cement AT the bricks without the arm contorting at full
         stretch. No collision on the nozzle (thin cosmetic tool; collision would make
         the planner avoid the wall it's meant to touch). -->
    <link name="${prefix}nozzle">
      <visual><geometry><cylinder radius="0.015" length="0.23"/></geometry><origin xyz="0 0 0.115"/><material name="tool_red"/></visual>
      <inertial><mass value="0.1"/><inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>

    <joint name="${prefix}tcp_joint" type="fixed">
      <parent link="${prefix}nozzle"/>
      <child link="${prefix}tcp"/>
      <origin xyz="0 0 0.23"/>
    </joint>
    <link name="${prefix}tcp"/>

    <!-- Wrist camera on the cement tool: looks down the tool +Z at the laid wall
         (DINO cement-following). Mirrors the gripper wrist cam. Distinct gz topic
         (${prefix}wrist_cam) so it doesn't clash with robot_a's /wrist_cam. -->
    <joint name="${prefix}wrist_cam_joint" type="fixed">
      <parent link="${prefix}cement_base"/>
      <child link="${prefix}wrist_cam_link"/>
      <origin xyz="0.12 0 0.05" rpy="0 -1.5708 0"/>
    </joint>
    <link name="${prefix}wrist_cam_link">
      <visual><geometry><box size="0.03 0.03 0.03"/></geometry></visual>
      <inertial><mass value="0.05"/><inertia ixx="1e-5" iyy="1e-5" izz="1e-5" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>
    <gazebo reference="${prefix}wrist_cam_link">
      <sensor name="wrist_cam" type="camera">
        <pose>0 0 0 0 0 0</pose>
        <always_on>1</always_on>
        <update_rate>15</update_rate>
        <visualize>true</visualize>
        <topic>${prefix}wrist_cam</topic>
        <gz_frame_id>${prefix}wrist_cam_link</gz_frame_id>
        <camera>
          <horizontal_fov>1.3</horizontal_fov>
          <image><width>640</width><height>480</height><format>R8G8B8</format></image>
          <clip><near>0.02</near><far>10.0</far></clip>
        </camera>
      </sensor>
    </gazebo>

  </xacro:macro>
</robot>
