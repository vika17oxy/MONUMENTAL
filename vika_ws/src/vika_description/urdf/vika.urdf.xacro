<?xml version="1.0"?>
<!--
  VIKA top-level composition.
  Usage:
    xacro vika.urdf.xacro prefix:=robot_a_ tool:=gripper
-->
<robot name="vika" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:arg name="prefix" default=""/>
  <xacro:arg name="tool"   default="gripper"/>
  <xacro:arg name="ns"     default=""/>
  <xacro:arg name="arm"    default="false"/>
  <!-- World anchor for this robot (spawn pose is ignored by the world-fixed
       rail, so bake placement here). base_yaw=3.14159 faces the robot -X. -->
  <xacro:arg name="base_x"   default="0"/>
  <xacro:arg name="base_yaw" default="0"/>
  <!-- use_meshes:=true loads the Fusion CAD STLs; false uses the primitive
       box/cylinder fallbacks that match the joint kinematics exactly. -->
  <xacro:arg name="use_meshes" default="true"/>

  <xacro:property name="pfx" value="$(arg prefix)"/>
  <xacro:property name="tool_type" value="$(arg tool)"/>
  <xacro:property name="ns" value="$(arg ns)"/>
  <xacro:property name="arm_enabled" value="$(arg arm)"/>
  <xacro:property name="base_x" value="$(arg base_x)"/>
  <xacro:property name="base_yaw" value="$(arg base_yaw)"/>
  <xacro:property name="use_meshes" value="$(arg use_meshes)"/>

  <xacro:include filename="$(find vika_description)/urdf/base_rail.xacro"/>
  <xacro:include filename="$(find vika_description)/urdf/arm_6dof.xacro"/>
  <xacro:include filename="$(find vika_description)/urdf/tool_gripper.xacro"/>
  <xacro:include filename="$(find vika_description)/urdf/tool_cement.xacro"/>
  <xacro:include filename="$(find vika_description)/urdf/vika.ros2_control.xacro"/>

  <!-- Linear rail base: arm rides a prismatic carriage along world +Y. -->
  <xacro:base_rail prefix="${pfx}" base_x="${base_x}" base_yaw="${base_yaw}"/>

  <xacro:if value="${arm_enabled}">
    <xacro:if value="${use_meshes}">
      <xacro:arm_6dof prefix="${pfx}arm_" parent="${pfx}base_link">
        <origin xyz="0 0 0.09" rpy="0 0 0"/>
      </xacro:arm_6dof>
    </xacro:if>
    <xacro:unless value="${use_meshes}">
      <xacro:arm_6dof prefix="${pfx}arm_" parent="${pfx}base_link"
                      mesh_base_link="" mesh_link1="" mesh_link2="" mesh_link3=""
                      mesh_link4="" mesh_link5="" mesh_tool0="">
        <origin xyz="0 0 0.09" rpy="0 0 0"/>
      </xacro:arm_6dof>
    </xacro:unless>

    <xacro:if value="${tool_type == 'gripper'}">
      <xacro:tool_gripper prefix="${pfx}arm_" parent="${pfx}arm_tool0"/>
    </xacro:if>
    <xacro:if value="${tool_type == 'cement'}">
      <xacro:tool_cement prefix="${pfx}arm_" parent="${pfx}arm_tool0"/>
    </xacro:if>
  </xacro:if>

  <!--
    ros2_control + gz_ros2_control: actuates the rail + arm (+ tool) joints so
    they hold position under gravity. Without this the unactuated revolute
    joints sag and the robot "collapses". Requires arm:=true.
  -->
  <xacro:if value="${arm_enabled}">
    <xacro:vika_ros2_control prefix="${pfx}" ns="${ns}" tool="${tool_type}"/>
  </xacro:if>

</robot>
