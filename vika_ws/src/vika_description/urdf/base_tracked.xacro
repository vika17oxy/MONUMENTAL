<?xml version="1.0"?>
<!-- Tracked mobile base: chassis + 2 tracks modeled as diff-drive wheels (Harmonic fallback). -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="base_tracked" params="prefix">

    <link name="${prefix}base_footprint"/>

    <joint name="${prefix}base_joint" type="fixed">
      <parent link="${prefix}base_footprint"/>
      <child link="${prefix}base_link"/>
      <origin xyz="0 0 0.2"/>
    </joint>

    <link name="${prefix}base_link">
      <visual>
        <geometry><box size="1.2 0.8 0.4"/></geometry>
        <material name="chassis_yellow"><color rgba="0.9 0.75 0.1 1"/></material>
      </visual>
      <collision><geometry><box size="1.2 0.8 0.4"/></geometry></collision>
      <inertial>
        <mass value="150.0"/>
        <inertia ixx="10.0" iyy="20.0" izz="25.0" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <xacro:macro name="track_wheel" params="side ysign">
      <joint name="${prefix}${side}_track_joint" type="continuous">
        <parent link="${prefix}base_link"/>
        <child link="${prefix}${side}_track_link"/>
        <origin xyz="0 ${ysign*0.45} -0.1" rpy="-1.5708 0 0"/>
        <axis xyz="0 0 1"/>
        <dynamics damping="0.5" friction="0.3"/>
      </joint>
      <link name="${prefix}${side}_track_link">
        <visual>
          <geometry><cylinder radius="0.2" length="0.15"/></geometry>
          <material name="track_black"><color rgba="0.1 0.1 0.1 1"/></material>
        </visual>
        <collision><geometry><cylinder radius="0.2" length="0.15"/></geometry></collision>
        <inertial>
          <mass value="10.0"/>
          <inertia ixx="0.1" iyy="0.1" izz="0.2" ixy="0" ixz="0" iyz="0"/>
        </inertial>
      </link>
    </xacro:macro>

    <xacro:track_wheel side="left"  ysign="1"/>
    <xacro:track_wheel side="right" ysign="-1"/>

    <!-- Gazebo DiffDrive system plugin: listens on /model/<name>/cmd_vel -->
    <gazebo>
      <plugin filename="gz-sim-diff-drive-system" name="gz::sim::systems::DiffDrive">
        <left_joint>${prefix}left_track_joint</left_joint>
        <right_joint>${prefix}right_track_joint</right_joint>
        <wheel_separation>0.9</wheel_separation>
        <wheel_radius>0.2</wheel_radius>
        <odom_publish_frequency>50</odom_publish_frequency>
        <max_linear_acceleration>1.0</max_linear_acceleration>
        <max_angular_acceleration>2.0</max_angular_acceleration>
        <topic>cmd_vel</topic>
      </plugin>
    </gazebo>

    <!-- Lidar mount -->
    <joint name="${prefix}lidar_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}lidar_link"/>
      <origin xyz="0.55 0 0.25"/>
    </joint>
    <link name="${prefix}lidar_link">
      <visual><geometry><cylinder radius="0.04" length="0.06"/></geometry><material name="sensor_blue"><color rgba="0.1 0.3 0.8 1"/></material></visual>
      <collision><geometry><cylinder radius="0.04" length="0.06"/></geometry></collision>
      <inertial><mass value="0.2"/><inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>

    <!-- IMU -->
    <joint name="${prefix}imu_joint" type="fixed">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}imu_link"/>
      <origin xyz="0 0 0.1"/>
    </joint>
    <link name="${prefix}imu_link">
      <inertial><mass value="0.05"/><inertia ixx="0.00001" iyy="0.00001" izz="0.00001" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>

  </xacro:macro>

</robot>
