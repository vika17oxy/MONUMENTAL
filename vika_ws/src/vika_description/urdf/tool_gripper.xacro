<?xml version="1.0"?>
<!-- Parallel-jaw gripper with mimic joint. -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="tool_gripper" params="prefix parent
                                           mesh_gripper:='package://vika_description/meshes/arm/ROD-STL/gripper.stl'">

    <joint name="${prefix}gripper_base_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${prefix}gripper_base"/>
      <origin xyz="0 0 0.04"/>
    </joint>
    <link name="${prefix}gripper_base">
      <visual>
        <xacro:if value="${len(mesh_gripper) &gt; 0}">
          <geometry><mesh filename="${mesh_gripper}" scale="0.001 0.001 0.001"/></geometry>
        </xacro:if>
        <xacro:unless value="${len(mesh_gripper) &gt; 0}">
          <geometry><box size="0.10 0.08 0.05"/></geometry>
        </xacro:unless>
        <material name="tool_grey"><color rgba="0.4 0.4 0.45 1"/></material>
      </visual>
      <collision>
        <xacro:if value="${len(mesh_gripper) &gt; 0}">
          <geometry><mesh filename="${mesh_gripper}" scale="0.001 0.001 0.001"/></geometry>
        </xacro:if>
        <xacro:unless value="${len(mesh_gripper) &gt; 0}">
          <geometry><box size="0.10 0.08 0.05"/></geometry>
        </xacro:unless>
      </collision>
      <inertial><mass value="0.5"/><inertia ixx="0.0005" iyy="0.0005" izz="0.0005" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>

    <joint name="${prefix}gripper_left_finger" type="prismatic">
      <parent link="${prefix}gripper_base"/>
      <child link="${prefix}left_finger"/>
      <origin xyz="0 0.02 0.05"/>
      <axis xyz="0 1 0"/>
      <limit lower="0.0" upper="0.04" effort="60" velocity="0.1"/>
    </joint>
    <link name="${prefix}left_finger">
      <visual><geometry><box size="0.02 0.015 0.08"/></geometry><origin xyz="0 0 0.04"/><material name="tool_grey"/></visual>
      <collision><geometry><box size="0.02 0.015 0.08"/></geometry><origin xyz="0 0 0.04"/></collision>
      <inertial><mass value="0.1"/><inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>

    <joint name="${prefix}gripper_right_finger" type="prismatic">
      <parent link="${prefix}gripper_base"/>
      <child link="${prefix}right_finger"/>
      <origin xyz="0 -0.02 0.05"/>
      <axis xyz="0 -1 0"/>
      <limit lower="0.0" upper="0.04" effort="60" velocity="0.1"/>
      <mimic joint="${prefix}gripper_left_finger" multiplier="1.0" offset="0"/>
    </joint>
    <link name="${prefix}right_finger">
      <visual><geometry><box size="0.02 0.015 0.08"/></geometry><origin xyz="0 0 0.04"/><material name="tool_grey"/></visual>
      <collision><geometry><box size="0.02 0.015 0.08"/></geometry><origin xyz="0 0 0.04"/></collision>
      <inertial><mass value="0.1"/><inertia ixx="0.0001" iyy="0.0001" izz="0.0001" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>

    <!-- TCP frame -->
    <joint name="${prefix}tcp_joint" type="fixed">
      <parent link="${prefix}gripper_base"/>
      <child link="${prefix}tcp"/>
      <origin xyz="0 0 0.13"/>
    </joint>
    <link name="${prefix}tcp"/>

  </xacro:macro>
</robot>
