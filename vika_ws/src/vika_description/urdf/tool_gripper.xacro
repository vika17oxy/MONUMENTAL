<?xml version="1.0"?>
<!-- Vacuum suction gripper sized to pick THREE bricks at once.
     A wide mounting bar (gripper_base) + 3 round suction pads, one per brick
     (bricks are 0.375 x 0.25 m, picked side-by-side along the bar's Y axis).
     Picking is on/off suction, so there are NO actuated joints. The link name
     `gripper_base` is kept because MoveIt (vika.srdf) and build_wall.py attach
     carried bricks to it; `tcp` is the suction contact frame (centre pad). -->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">
  <xacro:macro name="tool_gripper" params="prefix parent">

    <material name="tool_grey"><color rgba="0.4 0.4 0.45 1"/></material>
    <material name="suction_black"><color rgba="0.12 0.12 0.14 1"/></material>

    <!-- Wide mounting bar on the wrist flange (spans 3 bricks along Y) -->
    <joint name="${prefix}gripper_base_joint" type="fixed">
      <parent link="${parent}"/>
      <child link="${prefix}gripper_base"/>
      <origin xyz="0 0 0.02"/>
    </joint>
    <link name="${prefix}gripper_base">
      <visual>
        <origin xyz="0 0 0.02"/>
        <!-- bar spans the 3 pads at y=±0.375 (+pad radius) — 0.95 m is plenty;
             the old 1.45 m was sized for the wider 0.5 m pad spacing. -->
        <geometry><box size="0.34 0.95 0.04"/></geometry>
        <material name="tool_grey"/>
      </visual>
      <!-- No collision geometry: grasping is via the DetachableJoint (not contact),
           and the long bar's collision caused false self-collisions with the base
           that blocked motion / MoveIt planning. -->
      <inertial><mass value="1.2"/><inertia ixx="0.07" iyy="0.02" izz="0.08" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>

    <!-- One suction pad per brick, centred at the three brick positions (Y) -->
    <xacro:macro name="suction_pad" params="name y">
      <joint name="${prefix}${name}_joint" type="fixed">
        <parent link="${prefix}gripper_base"/>
        <child link="${prefix}${name}"/>
        <origin xyz="0 ${y} 0.06"/>
      </joint>
      <link name="${prefix}${name}">
        <visual>
          <geometry><cylinder radius="0.09" length="0.04"/></geometry>
          <material name="suction_black"/>
        </visual>
        <!-- no collision (attach-based grasping) -->
        <inertial><mass value="0.15"/><inertia ixx="0.0002" iyy="0.0002" izz="0.0003" ixy="0" ixz="0" iyz="0"/></inertial>
      </link>
    </xacro:macro>

    <!-- pad spacing 0.375 = brick long side EXACTLY, so the placed row sits
         flush (zero gap) along world X. With the längs pick yaw the bar (local
         Y) runs along world X = along the bricks' long axis. -->
    <xacro:suction_pad name="suction_pad_l" y="0.375"/>
    <xacro:suction_pad name="suction_pad_c" y="0.0"/>
    <xacro:suction_pad name="suction_pad_r" y="-0.375"/>

    <!-- TCP at the centre pad contact face -->
    <joint name="${prefix}tcp_joint" type="fixed">
      <parent link="${prefix}suction_pad_c"/>
      <child link="${prefix}tcp"/>
      <origin xyz="0 0 0.02"/>
    </joint>
    <link name="${prefix}tcp"/>

    <!-- Wrist camera: mounted at the bar edge (clear of the pads), looking down
         the tool +Z (= world -Z when the gripper is top-down) at the bricks.
         gz cameras look along the sensor frame +X, so pitch -90deg aims +X at
         the parent +Z. Used by the DINO brick detector + HMI wrist view. -->
    <joint name="${prefix}wrist_cam_joint" type="fixed">
      <parent link="${prefix}gripper_base"/>
      <child link="${prefix}wrist_cam_link"/>
      <origin xyz="0.22 0 0.03" rpy="0 -1.5708 0"/>
    </joint>
    <link name="${prefix}wrist_cam_link">
      <visual>
        <geometry><box size="0.03 0.03 0.03"/></geometry>
        <material name="suction_black"/>
      </visual>
      <inertial><mass value="0.05"/><inertia ixx="1e-5" iyy="1e-5" izz="1e-5" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>
    <gazebo reference="${prefix}wrist_cam_link">
      <sensor name="wrist_cam" type="camera">
        <pose>0 0 0 0 0 0</pose>
        <always_on>1</always_on>
        <update_rate>15</update_rate>
        <visualize>true</visualize>
        <topic>wrist_cam</topic>
        <gz_frame_id>${prefix}wrist_cam_link</gz_frame_id>
        <camera>
          <horizontal_fov>1.3</horizontal_fov>
          <image><width>640</width><height>480</height><format>R8G8B8</format></image>
          <clip><near>0.02</near><far>10.0</far></clip>
        </camera>
      </sensor>
    </gazebo>

    <!-- Vacuum "suction": one gz DetachableJoint per brick. Each starts DETACHED
         (attach_topic given) and creates a fixed joint to its brick model when
         an Empty msg hits the attach topic; the detach topic releases it.
         NOTE: the suction-pad links are lumped into ${prefix}tool0 by URDF->SDF
         fixed-joint reduction, so the surviving parent link is tool0. The brick
         attaches at its current relative pose, so it stays under its pad. -->
    <!-- ONE DetachableJoint per dynamic pick-ROW. The pallet holds a flat 3x3 layer
         of 3 rows (row_0_0/1_0/2_0, 3 fused bricks each). The gripper grabs a whole
         row; after laying it as a wall SEGMENT (static bricks) the row is respawned
         to its pallet slot. Flat single layer never topples (old 3x4 stack did). -->
    <gazebo>
      <plugin filename="gz-sim-detachable-joint-system" name="gz::sim::systems::DetachableJoint">
        <parent_link>${prefix}tool0</parent_link>
        <child_model>row_0_0</child_model>
        <child_link>row</child_link>
        <attach_topic>/suction/r0_0/attach</attach_topic>
        <detach_topic>/suction/r0_0/detach</detach_topic>
        <output_topic>/suction/r0_0/state</output_topic>
        <suppress_child_warning>true</suppress_child_warning>
      </plugin>
    </gazebo>

  </xacro:macro>
</robot>
