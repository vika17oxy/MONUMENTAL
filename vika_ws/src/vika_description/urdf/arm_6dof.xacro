<?xml version="1.0"?>
<!--
  6-DOF serial arm — mountable on the tracked base.

  Joint origins are auto-generated by MCP from the Fusion 360 assembly
  (home pose = current CAD pose), identical to base_only.urdf.xacro:
    - Every joint origin carries the proximal-joint position AND the rpy that
      orients the child link's frame.
    - Every joint axis is therefore the child's local +Z.
    - The STL meshes are authored AT each joint frame, so every visual/collision
      origin is identity (0 0 0).

  Per-link STL drop-in: pass mesh_<linkname>:=<package://...> to override.
  An EMPTY string falls back to a primitive block placed at the joint frame.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="arm_6dof" params="prefix parent
                                       define_materials:=true
                                       mesh_base_link:='package://vika_description/meshes/arm/ROD-STL/base.stl'
                                       mesh_link1:='package://vika_description/meshes/arm/ROD-STL/link1.stl'
                                       mesh_link2:='package://vika_description/meshes/arm/ROD-STL/link2.stl'
                                       mesh_link3:='package://vika_description/meshes/arm/ROD-STL/link3.stl'
                                       mesh_link4:='package://vika_description/meshes/arm/ROD-STL/link4.stl'
                                       mesh_link5:='package://vika_description/meshes/arm/ROD-STL/link5.stl'
                                       mesh_tool0:='package://vika_description/meshes/arm/ROD-STL/link6.stl'
                                       *origin">

    <!-- Reusable swap macro: mesh if non-empty, else fallback primitive block. -->
    <xacro:macro name="geom_or_mesh" params="mesh_uri *fallback">
      <xacro:if value="${len(mesh_uri) &gt; 0}">
        <geometry><mesh filename="${mesh_uri}" scale="0.001 0.001 0.001"/></geometry>
      </xacro:if>
      <xacro:unless value="${len(mesh_uri) &gt; 0}">
        <xacro:insert_block name="fallback"/>
      </xacro:unless>
    </xacro:macro>

    <xacro:if value="${define_materials}">
      <material name="arm_grey"><color rgba="0.3 0.3 0.3 1"/></material>
      <material name="arm_orange"><color rgba="0.92 0.45 0.10 1"/></material>
    </xacro:if>

    <!-- Shoulder mount plate (caller supplies the origin on the base) -->
    <joint name="${prefix}mount_joint" type="fixed">
      <xacro:insert_block name="origin"/>
      <parent link="${parent}"/>
      <child link="${prefix}base_link"/>
    </joint>

    <link name="${prefix}base_link">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <xacro:geom_or_mesh mesh_uri="${mesh_base_link}">
          <geometry><cylinder radius="0.12" length="0.15"/></geometry>
        </xacro:geom_or_mesh>
        <material name="arm_grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <xacro:geom_or_mesh mesh_uri="${mesh_base_link}">
          <geometry><cylinder radius="0.12" length="0.15"/></geometry>
        </xacro:geom_or_mesh>
      </collision>
      <inertial>
        <mass value="3.0"/>
        <inertia ixx="0.05" iyy="0.05" izz="0.08" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <!-- J1: base yaw -->
    <joint name="${prefix}j1" type="revolute">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}link1"/>
      <origin xyz="0 0 0.175" rpy="0 0 1.5152"/>
      <axis xyz="0 0 1"/>
      <limit lower="-3.14" upper="3.14" effort="80" velocity="3.14"/>
      <dynamics damping="0.5" friction="0.1"/>
    </joint>
    <link name="${prefix}link1">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <xacro:geom_or_mesh mesh_uri="${mesh_link1}">
          <geometry><box size="0.18 0.18 0.25"/></geometry>
        </xacro:geom_or_mesh>
        <material name="arm_orange"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <xacro:geom_or_mesh mesh_uri="${mesh_link1}">
          <geometry><box size="0.18 0.18 0.25"/></geometry>
        </xacro:geom_or_mesh>
      </collision>
      <inertial><mass value="6.0"/><inertia ixx="0.10" iyy="0.10" izz="0.06" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>

    <!-- J2: shoulder pitch -->
    <joint name="${prefix}j2" type="revolute">
      <parent link="${prefix}link1"/>
      <child link="${prefix}link2"/>
      <origin xyz="0.1038 -0.4023 0.2912" rpy="1.5708 0 -1.5708"/>
      <axis xyz="0 0 1"/>
      <limit lower="-2.70" upper="2.70" effort="80" velocity="2.5"/>
      <dynamics damping="0.5" friction="0.1"/>
    </joint>
    <link name="${prefix}link2">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <xacro:geom_or_mesh mesh_uri="${mesh_link2}">
          <geometry><box size="0.12 0.14 0.55"/></geometry>
        </xacro:geom_or_mesh>
        <material name="arm_orange"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <xacro:geom_or_mesh mesh_uri="${mesh_link2}">
          <geometry><box size="0.12 0.14 0.55"/></geometry>
        </xacro:geom_or_mesh>
      </collision>
      <inertial><mass value="5.0"/><inertia ixx="0.7" iyy="0.05" izz="0.7" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>

    <!-- J3: elbow -->
    <joint name="${prefix}j3" type="revolute">
      <parent link="${prefix}link2"/>
      <child link="${prefix}link3"/>
      <origin xyz="0 1.300 0" rpy="0 0 -0.2221"/>
      <axis xyz="0 0 1"/>
      <limit lower="-2.70" upper="2.70" effort="60" velocity="2.8"/>
      <dynamics damping="0.5" friction="0.1"/>
    </joint>
    <link name="${prefix}link3">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <xacro:geom_or_mesh mesh_uri="${mesh_link3}">
          <geometry><box size="0.10 0.12 0.45"/></geometry>
        </xacro:geom_or_mesh>
        <material name="arm_orange"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <xacro:geom_or_mesh mesh_uri="${mesh_link3}">
          <geometry><box size="0.10 0.12 0.45"/></geometry>
        </xacro:geom_or_mesh>
      </collision>
      <inertial><mass value="3.5"/><inertia ixx="0.07" iyy="0.07" izz="0.01" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>

    <!-- J4: wrist roll -->
    <joint name="${prefix}j4" type="revolute">
      <parent link="${prefix}link3"/>
      <child link="${prefix}link4"/>
      <origin xyz="0.1600 0.2369 0.0003" rpy="1.5708 0.9923 1.5708"/>
      <axis xyz="0 0 1"/>
      <limit lower="-6.10" upper="6.10" effort="20" velocity="5.0"/>
      <dynamics damping="0.2" friction="0.05"/>
    </joint>
    <link name="${prefix}link4">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <xacro:geom_or_mesh mesh_uri="${mesh_link4}">
          <geometry><cylinder radius="0.05" length="0.12"/></geometry>
        </xacro:geom_or_mesh>
        <material name="arm_grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <xacro:geom_or_mesh mesh_uri="${mesh_link4}">
          <geometry><cylinder radius="0.05" length="0.12"/></geometry>
        </xacro:geom_or_mesh>
      </collision>
      <inertial><mass value="1.5"/><inertia ixx="0.05" iyy="0.05" izz="0.005" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>

    <!-- J5: wrist pitch -->
    <joint name="${prefix}j5" type="revolute">
      <parent link="${prefix}link4"/>
      <child link="${prefix}link5"/>
      <origin xyz="-0.0860 0 1.3050" rpy="1.5708 -1.3556 -1.5708"/>
      <axis xyz="0 0 1"/>
      <limit lower="-2.27" upper="2.27" effort="20" velocity="5.0"/>
      <dynamics damping="0.2" friction="0.05"/>
    </joint>
    <link name="${prefix}link5">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <xacro:geom_or_mesh mesh_uri="${mesh_link5}">
          <geometry><box size="0.08 0.08 0.08"/></geometry>
        </xacro:geom_or_mesh>
        <material name="arm_grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <xacro:geom_or_mesh mesh_uri="${mesh_link5}">
          <geometry><box size="0.08 0.08 0.08"/></geometry>
        </xacro:geom_or_mesh>
      </collision>
      <inertial><mass value="0.8"/><inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>

    <!-- J6: tool roll. Child carries link6.stl and serves as the tool0 flange. -->
    <joint name="${prefix}j6" type="revolute">
      <parent link="${prefix}link5"/>
      <child link="${prefix}tool0"/>
      <origin xyz="0.1600 0 -0.0850" rpy="-1.5708 1.3440 -1.5708"/>
      <axis xyz="0 0 1"/>
      <limit lower="-6.10" upper="6.10" effort="15" velocity="6.0"/>
      <dynamics damping="0.1" friction="0.02"/>
    </joint>
    <link name="${prefix}tool0">
      <visual>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <xacro:geom_or_mesh mesh_uri="${mesh_tool0}">
          <geometry><cylinder radius="0.035" length="0.04"/></geometry>
        </xacro:geom_or_mesh>
        <material name="arm_grey"/>
      </visual>
      <collision>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <xacro:geom_or_mesh mesh_uri="${mesh_tool0}">
          <geometry><cylinder radius="0.035" length="0.04"/></geometry>
        </xacro:geom_or_mesh>
      </collision>
      <inertial><mass value="0.3"/><inertia ixx="0.0002" iyy="0.0002" izz="0.0002" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>

  </xacro:macro>

</robot>
