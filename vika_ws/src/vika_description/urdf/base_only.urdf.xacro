<?xml version="1.0"?>
<!--
  Auto-generated by MCP from Fusion 360 assembly state.
  Source pose: assembly v15 (current CAD pose taken as URDF home pose).
  Currently: base + link1 only (test).

  Convention:
    - base_link sits at world origin
    - Each joint origin is the proximal-joint position in the parent's local frame
    - At all joints = 0, robot pose matches the CAD's current pose
    - STL units: mm (scale 0.001), mesh origins as authored in CAD components
-->
<robot name="vika_step" xmlns:xacro="http://www.ros.org/wiki/xacro">

  <!-- sim_mode: "mock" (mock_components, RViz/MoveIt only) or "gazebo" (gz_ros2_control + Gazebo plugin) -->
  <xacro:arg name="sim_mode" default="mock"/>
  <xacro:property name="sim_mode" value="$(arg sim_mode)"/>

  <!-- end-effector mesh — swap to e.g. "nozzle.stl" for the twin -->
  <xacro:arg name="ee_mesh" default="gripper.stl"/>
  <xacro:property name="ee_mesh" value="$(arg ee_mesh)"/>

  <!-- end-effector mount rpy (relative to tool0). Gripper authored with its
       grasping Z-axis pointing INTO the flange → needs a 180° roll flip.
       Nozzle authored with its working Z-axis pointing OUT → no flip needed. -->
  <xacro:arg name="ee_rpy" default="-3.1416 0 -0.7298"/>
  <xacro:property name="ee_rpy" value="$(arg ee_rpy)"/>

  <xacro:property name="mesh_dir" value="package://vika_description/meshes/arm/ROD-STL"/>
  <xacro:property name="mesh_scale" value="0.001 0.001 0.001"/>

  <material name="steel"><color rgba="0.75 0.75 0.78 1"/></material>
  <material name="orange"><color rgba="0.92 0.45 0.10 1"/></material>

  <link name="world"/>

  <!-- ============================================================ -->
  <!-- BASE                                                          -->
  <!-- Fusion: base v5, grounded, identity rotation                  -->
  <!-- ============================================================ -->
  <link name="base_link">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_dir}/base.stl" scale="${mesh_scale}"/></geometry>
      <material name="steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_dir}/base.stl" scale="${mesh_scale}"/></geometry>
    </collision>
    <inertial>
      <mass value="3.0"/>
      <inertia ixx="0.05" iyy="0.05" izz="0.08" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child  link="base_link"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>

  <!-- ============================================================ -->
  <!-- J1 — Base yaw (revolute around Z)                             -->
  <!-- MCP: link1 sits at (0, 0, 0.1750) m in base frame             -->
  <!-- Home-pose rotation 86.8° around Z baked into joint rpy        -->
  <!-- ============================================================ -->
  <joint name="j1" type="revolute">
    <parent link="base_link"/>
    <child  link="link1"/>
    <origin xyz="0 0 0.175" rpy="0 0 1.5152"/>
    <axis xyz="0 0 1"/>
    <limit lower="-3.14" upper="3.14" effort="80" velocity="3.14"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <link name="link1">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_dir}/link1.stl" scale="${mesh_scale}"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_dir}/link1.stl" scale="${mesh_scale}"/></geometry>
    </collision>
    <inertial>
      <mass value="6.0"/>
      <inertia ixx="0.10" iyy="0.10" izz="0.06" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ============================================================ -->
  <!-- J2 — Shoulder pitch (revolute around link2's local Z)         -->
  <!-- MCP: link2 in link1 frame = xyz(0.104,-0.402,0.291)           -->
  <!-- rpy decomposed from R_link1^T * R_link2: (π/2, 0, -π/2)       -->
  <!-- ============================================================ -->
  <joint name="j2" type="revolute">
    <parent link="link1"/>
    <child  link="link2"/>
    <origin xyz="0.1038 -0.4023 0.2912" rpy="1.5708 0 -1.5708"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.70" upper="2.70" effort="80" velocity="2.5"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <link name="link2">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_dir}/link2.stl" scale="${mesh_scale}"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_dir}/link2.stl" scale="${mesh_scale}"/></geometry>
    </collision>
    <inertial>
      <mass value="5.0"/>
      <inertia ixx="0.7" iyy="0.05" izz="0.7" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ============================================================ -->
  <!-- J3 — Elbow (revolute around link3's local Z)                  -->
  <!-- MCP: link3 in link2 frame = xyz(0, 1.300, 0) m                -->
  <!-- rpy (-12.7° around Z) = current CAD home-pose offset          -->
  <!-- ============================================================ -->
  <joint name="j3" type="revolute">
    <parent link="link2"/>
    <child  link="link3"/>
    <origin xyz="0 1.300 0" rpy="0 0 -0.2221"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.70" upper="2.70" effort="60" velocity="2.8"/>
    <dynamics damping="0.5" friction="0.1"/>
  </joint>

  <link name="link3">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_dir}/link3.stl" scale="${mesh_scale}"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_dir}/link3.stl" scale="${mesh_scale}"/></geometry>
    </collision>
    <inertial>
      <mass value="3.5"/>
      <inertia ixx="0.07" iyy="0.07" izz="0.01" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ============================================================ -->
  <!-- J4 — Wrist roll (revolute around link4's local Z)             -->
  <!-- In sim_mode=passive: locked (fixed joint) — for "broken twin" -->
  <!-- ============================================================ -->
  <xacro:if value="${sim_mode == 'passive'}">
    <joint name="j4" type="fixed">
      <parent link="link3"/>
      <child  link="link4"/>
      <origin xyz="0.1600 0.2369 0.0003" rpy="1.5708 0.9923 1.5708"/>
    </joint>
  </xacro:if>
  <xacro:unless value="${sim_mode == 'passive'}">
    <joint name="j4" type="revolute">
      <parent link="link3"/>
      <child  link="link4"/>
      <origin xyz="0.1600 0.2369 0.0003" rpy="1.5708 0.9923 1.5708"/>
      <axis xyz="0 0 1"/>
      <limit lower="-6.10" upper="6.10" effort="20" velocity="5.0"/>
      <dynamics damping="0.2" friction="0.05"/>
    </joint>
  </xacro:unless>

  <link name="link4">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_dir}/link4.stl" scale="${mesh_scale}"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_dir}/link4.stl" scale="${mesh_scale}"/></geometry>
    </collision>
    <inertial>
      <mass value="1.5"/>
      <inertia ixx="0.05" iyy="0.05" izz="0.005" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ============================================================ -->
  <!-- J5 — Wrist pitch (revolute around link5's local Z)            -->
  <!-- MCP: link5 in link4 frame = xyz(-0.086, -0.117, 1.381) m      -->
  <!-- (link4 is long, link5 sits 1.38m along link4's Z-axis)        -->
  <!-- ============================================================ -->
  <joint name="j5" type="revolute">
    <parent link="link4"/>
    <child  link="link5"/>
    <origin xyz="-0.0860 0 1.3050" rpy="1.5708 -1.3556 -1.5708"/>
    <axis xyz="0 0 1"/>
    <limit lower="-2.27" upper="2.27" effort="20" velocity="5.0"/>
    <dynamics damping="0.2" friction="0.05"/>
  </joint>

  <link name="link5">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_dir}/link5.stl" scale="${mesh_scale}"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_dir}/link5.stl" scale="${mesh_scale}"/></geometry>
    </collision>
    <inertial>
      <mass value="0.8"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ============================================================ -->
  <!-- J6 — Tool roll (revolute around link6's local Z)              -->
  <!-- MCP: link6 in link5 frame = xyz(0.160, 0, -0.085) m           -->
  <!-- ============================================================ -->
  <joint name="j6" type="revolute">
    <parent link="link5"/>
    <child  link="link6"/>
    <origin xyz="0.1600 0 -0.0850" rpy="-1.5708 1.3440 -1.5708"/>
    <axis xyz="0 0 1"/>
    <limit lower="-6.10" upper="6.10" effort="15" velocity="6.0"/>
    <dynamics damping="0.1" friction="0.02"/>
  </joint>

  <link name="link6">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_dir}/link6.stl" scale="${mesh_scale}"/></geometry>
      <material name="orange"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_dir}/link6.stl" scale="${mesh_scale}"/></geometry>
    </collision>
    <inertial>
      <mass value="0.3"/>
      <inertia ixx="0.0002" iyy="0.0002" izz="0.0002" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ============================================================ -->
  <!-- TOOL0 — flange frame for tool mounting (= MoveIt EE chain end) -->
  <!-- Coincides with link6's local +Z face (flange surface)         -->
  <!-- ============================================================ -->
  <joint name="link6_to_tool0" type="fixed">
    <parent link="link6"/>
    <child  link="tool0"/>
    <origin xyz="0 0 0" rpy="0 0 0"/>
  </joint>
  <link name="tool0"/>

  <!-- ============================================================ -->
  <!-- GRIPPER — rigid for now; mini-jaws can be added later as       -->
  <!-- prismatic children of gripper_base.                           -->
  <!-- MCP: gripper origin in link6 = xyz(0, 0, 0.020) m              -->
  <!-- rpy=(-180°, 0°, -41.8°)                                       -->
  <!-- ============================================================ -->
  <joint name="tool0_to_gripper" type="fixed">
    <parent link="tool0"/>
    <child  link="gripper_base"/>
    <origin xyz="0 0 0.0200" rpy="${ee_rpy}"/>
  </joint>

  <link name="gripper_base">
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_dir}/${ee_mesh}" scale="${mesh_scale}"/></geometry>
      <material name="steel"/>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry><mesh filename="${mesh_dir}/${ee_mesh}" scale="${mesh_scale}"/></geometry>
    </collision>
    <inertial>
      <mass value="0.5"/>
      <inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/>
    </inertial>
  </link>

  <!-- ============================================================ -->
  <!-- TCP — virtual frame at the grip point.                        -->
  <!-- rpy here rotates TCP so its +Z aligns with the gripper's      -->
  <!-- grasping direction (so MoveIt "Z-down" constraints work).     -->
  <!-- ============================================================ -->
  <joint name="gripper_to_tcp" type="fixed">
    <parent link="gripper_base"/>
    <child  link="tcp"/>
    <origin xyz="0 0 0.10" rpy="0 0 0"/>
  </joint>
  <link name="tcp"/>

  <!-- ============================================================ -->
  <!-- ros2_control + Gazebo plugin: only in mock or gazebo mode     -->
  <!-- (passive mode = visual-only twin, no controller)              -->
  <!-- ============================================================ -->
  <xacro:unless value="${sim_mode == 'passive'}">
    <ros2_control name="vika_${sim_mode}_system" type="system">
      <hardware>
        <xacro:if value="${sim_mode == 'mock'}">
          <plugin>mock_components/GenericSystem</plugin>
        </xacro:if>
        <xacro:if value="${sim_mode == 'gazebo'}">
          <plugin>gz_ros2_control/GazeboSimSystem</plugin>
        </xacro:if>
      </hardware>
      <xacro:macro name="jif" params="name">
        <joint name="${name}">
          <command_interface name="position"/>
          <state_interface name="position"><param name="initial_value">0.0</param></state_interface>
          <state_interface name="velocity"/>
        </joint>
      </xacro:macro>
      <xacro:jif name="j1"/>
      <xacro:jif name="j2"/>
      <xacro:jif name="j3"/>
      <xacro:jif name="j4"/>
      <xacro:jif name="j5"/>
      <xacro:jif name="j6"/>
    </ros2_control>
  </xacro:unless>

  <xacro:if value="${sim_mode == 'gazebo'}">
    <gazebo>
      <plugin filename="gz_ros2_control-system" name="gz_ros2_control::GazeboSimROS2ControlPlugin">
        <parameters>/ws/src/vika_moveit/config/vika_ros2_controllers.yaml</parameters>
      </plugin>
    </gazebo>
  </xacro:if>

</robot>
