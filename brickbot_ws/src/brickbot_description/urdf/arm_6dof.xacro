<?xml version="1.0"?>
<!--
  6-DOF serial anthropomorphic arm (RRR-RRR).
  Geometry and dynamics are placeholders sized like a KUKA-KR6-class arm but
  self-designed; replace mesh references and tune inertias as CAD progresses.
-->
<robot xmlns:xacro="http://www.ros.org/wiki/xacro">

  <xacro:macro name="arm_6dof" params="prefix parent *origin">

    <!-- Shoulder mount plate -->
    <joint name="${prefix}mount_joint" type="fixed">
      <xacro:insert_block name="origin"/>
      <parent link="${parent}"/>
      <child link="${prefix}base_link"/>
    </joint>

    <link name="${prefix}base_link">
      <visual>
        <geometry><cylinder radius="0.12" length="0.15"/></geometry>
        <origin xyz="0 0 0.075"/>
        <material name="arm_grey"><color rgba="0.3 0.3 0.3 1"/></material>
      </visual>
      <collision>
        <geometry><cylinder radius="0.12" length="0.15"/></geometry>
        <origin xyz="0 0 0.075"/>
      </collision>
      <inertial>
        <mass value="4.0"/>
        <inertia ixx="0.02" iyy="0.02" izz="0.03" ixy="0" ixz="0" iyz="0"/>
      </inertial>
    </link>

    <!-- J1: Base rotation -->
    <joint name="${prefix}j1" type="revolute">
      <parent link="${prefix}base_link"/>
      <child link="${prefix}link1"/>
      <origin xyz="0 0 0.15" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-3.23" upper="3.23" effort="80" velocity="3.14"/>
      <dynamics damping="0.5" friction="0.1"/>
    </joint>
    <link name="${prefix}link1">
      <visual>
        <geometry><box size="0.18 0.18 0.25"/></geometry>
        <origin xyz="0 0 0.125"/>
        <material name="arm_orange"><color rgba="0.9 0.5 0.1 1"/></material>
      </visual>
      <collision><geometry><box size="0.18 0.18 0.25"/></geometry><origin xyz="0 0 0.125"/></collision>
      <inertial><mass value="6.0"/><inertia ixx="0.05" iyy="0.05" izz="0.03" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>

    <!-- J2: Shoulder pitch -->
    <joint name="${prefix}j2" type="revolute">
      <parent link="${prefix}link1"/>
      <child link="${prefix}link2"/>
      <origin xyz="0.1 0 0.25" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-2.70" upper="0.61" effort="80" velocity="2.5"/>
      <dynamics damping="0.5" friction="0.1"/>
    </joint>
    <link name="${prefix}link2">
      <visual>
        <geometry><box size="0.12 0.14 0.55"/></geometry>
        <origin xyz="0 0 0.275"/>
        <material name="arm_orange"/>
      </visual>
      <collision><geometry><box size="0.12 0.14 0.55"/></geometry><origin xyz="0 0 0.275"/></collision>
      <inertial><mass value="5.0"/><inertia ixx="0.14" iyy="0.14" izz="0.02" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>

    <!-- J3: Elbow -->
    <joint name="${prefix}j3" type="revolute">
      <parent link="${prefix}link2"/>
      <child link="${prefix}link3"/>
      <origin xyz="0 0 0.55" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-2.27" upper="2.69" effort="60" velocity="2.8"/>
      <dynamics damping="0.5" friction="0.1"/>
    </joint>
    <link name="${prefix}link3">
      <visual>
        <geometry><box size="0.10 0.12 0.45"/></geometry>
        <origin xyz="0 0 0.225"/>
        <material name="arm_orange"/>
      </visual>
      <collision><geometry><box size="0.10 0.12 0.45"/></geometry><origin xyz="0 0 0.225"/></collision>
      <inertial><mass value="3.5"/><inertia ixx="0.07" iyy="0.07" izz="0.01" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>

    <!-- J4: Wrist roll -->
    <joint name="${prefix}j4" type="revolute">
      <parent link="${prefix}link3"/>
      <child link="${prefix}link4"/>
      <origin xyz="0 0 0.45" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-6.10" upper="6.10" effort="20" velocity="5.0"/>
      <dynamics damping="0.2" friction="0.05"/>
    </joint>
    <link name="${prefix}link4">
      <visual><geometry><cylinder radius="0.05" length="0.12"/></geometry><origin xyz="0 0 0.06"/><material name="arm_grey"/></visual>
      <collision><geometry><cylinder radius="0.05" length="0.12"/></geometry><origin xyz="0 0 0.06"/></collision>
      <inertial><mass value="1.2"/><inertia ixx="0.002" iyy="0.002" izz="0.001" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>

    <!-- J5: Wrist pitch -->
    <joint name="${prefix}j5" type="revolute">
      <parent link="${prefix}link4"/>
      <child link="${prefix}link5"/>
      <origin xyz="0 0 0.12" rpy="0 0 0"/>
      <axis xyz="0 1 0"/>
      <limit lower="-2.27" upper="2.27" effort="20" velocity="5.0"/>
      <dynamics damping="0.2" friction="0.05"/>
    </joint>
    <link name="${prefix}link5">
      <visual><geometry><box size="0.08 0.08 0.08"/></geometry><origin xyz="0 0 0.04"/><material name="arm_grey"/></visual>
      <collision><geometry><box size="0.08 0.08 0.08"/></geometry><origin xyz="0 0 0.04"/></collision>
      <inertial><mass value="0.8"/><inertia ixx="0.001" iyy="0.001" izz="0.001" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>

    <!-- J6: Tool rotation -->
    <joint name="${prefix}j6" type="revolute">
      <parent link="${prefix}link5"/>
      <child link="${prefix}tool0"/>
      <origin xyz="0 0 0.08" rpy="0 0 0"/>
      <axis xyz="0 0 1"/>
      <limit lower="-6.10" upper="6.10" effort="15" velocity="6.0"/>
      <dynamics damping="0.1" friction="0.02"/>
    </joint>
    <link name="${prefix}tool0">
      <visual><geometry><cylinder radius="0.035" length="0.04"/></geometry><origin xyz="0 0 0.02"/><material name="arm_grey"/></visual>
      <collision><geometry><cylinder radius="0.035" length="0.04"/></geometry><origin xyz="0 0 0.02"/></collision>
      <inertial><mass value="0.3"/><inertia ixx="0.0002" iyy="0.0002" izz="0.0002" ixy="0" ixz="0" iyz="0"/></inertial>
    </link>

  </xacro:macro>

</robot>
